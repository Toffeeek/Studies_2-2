<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="210.0" prefWidth="361.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.FirstSceneController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="394.0" spacing="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="First Number: ">
               <padding>
                  <Insets bottom="5.0" top="5.0" />
               </padding>
            </Label>
            <TextField fx:id="firstNumberField" maxWidth="-Infinity" minWidth="-Infinity" />
            <Label text="Second Number:" />
            <TextField fx:id="secondNumberField" maxWidth="-Infinity" minWidth="-Infinity" />
            <Button mnemonicParsing="false" onAction="#handleCalculate" text="Calculate Sum">
               <padding>
                  <Insets bottom="5.0" top="5.0" />
               </padding>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>
